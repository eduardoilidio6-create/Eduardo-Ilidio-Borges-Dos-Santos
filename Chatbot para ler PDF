# Função usada para obter as respostas do Bot

def resposta_bot(mensagens):

  # Unindo as duas fontes no prompt do sistema

  instrucao = (

    "Você é o assistente Aegis. Responda APENAS com base nos documentos abaixo. "

    "Se a informação não estiver neles, diga: 'Informação não encontrada.' "

    "Não use seu conhecimento externo. Seja direto."

    f"\n\nFONTE SITE:\n{dados_site}"

    f"\n\nFONTE PDF:\n{dados_pdf}"

  )

  

  mensagens_modelo = [('system', instrucao)]

  mensagens_modelo += mensagens

  template = ChatPromptTemplate.from_messages(mensagens_modelo)

  chain = template | chat

  return chain.invoke({}).content



