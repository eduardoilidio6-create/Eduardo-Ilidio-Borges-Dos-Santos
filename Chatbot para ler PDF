# --- FONTE 1: O SITE ---

def extrair_conteudo_site(url):

  try:

    response = requests.get(url)

    if response.status_code == 200:

      soup = BeautifulSoup(response.text, 'html.parser')

      conteudo = soup.find_all(['p', 'code'])

      return "\n".join([item.get_text() for item in conteudo])[:2000] # Limite de caracteres

  except:

    return "Erro ao acessar o site."

  return ""



