    ("user", "Conteúdo: {documentos_informados}\nPergunta: {pergunta_do_usuario}")

  ])

  

  chain = template | chat

  print("Lógica configurada.")



  # 5. Interação - O PROBLEMA PODE ESTAR AQUI

  print("\n--- AGUARDANDO DIGITAÇÃO ---")

  pergunta = input("Digite sua pergunta aqui: ")



  if pergunta:

    print("Enviando para a IA...")

    resposta = chain.invoke({

      "documentos_informados": conteudo_video,

      "pergunta_do_usuario": pergunta

